#!/usr/bin/env bash
set -euo pipefail

TARGET_HOST="${TARGET_HOST:-hetzner}"
TARGET_DIR="${TARGET_DIR:-/opt/voice-bridge}"
BRANCH="${BRANCH:-main}"
REPO_SSH_URL="${REPO_SSH_URL:-}"

if [[ -z "${REPO_SSH_URL}" ]]; then
  echo "Set REPO_SSH_URL, e.g. git@github.com:<owner>/talka.git"
  exit 1
fi

ssh "${TARGET_HOST}" bash -s -- "${TARGET_DIR}" "${BRANCH}" "${REPO_SSH_URL}" <<'EOF'
set -euo pipefail
TARGET_DIR="$1"
BRANCH="$2"
REPO_SSH_URL="$3"

if [[ -d "${TARGET_DIR}" && ! -d "${TARGET_DIR}/.git" ]]; then
  TS="$(date +%Y%m%d-%H%M%S)"
  cp -a "${TARGET_DIR}" "${TARGET_DIR}.backup.${TS}"
  rm -rf "${TARGET_DIR}"
fi

if [[ ! -d "${TARGET_DIR}/.git" ]]; then
  git clone --branch "${BRANCH}" "${REPO_SSH_URL}" "${TARGET_DIR}"
fi

cd "${TARGET_DIR}"
git fetch origin
git checkout "${BRANCH}"
git pull --ff-only origin "${BRANCH}"
BRANCH="${BRANCH}" ./deploy/scripts/voice-bridge-pull-deploy
EOF
