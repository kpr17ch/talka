#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${REPO_DIR:-/opt/voice-bridge}"
BRANCH="${BRANCH:-main}"
SERVICE_NAME="${SERVICE_NAME:-voice-bridge.service}"
APP_HOST="${APP_HOST:-127.0.0.1}"
APP_PORT="${APP_PORT:-8089}"
PYTHON_BIN="${PYTHON_BIN:-python3}"

echo "[deploy] repo=${REPO_DIR} branch=${BRANCH} service=${SERVICE_NAME}"
cd "${REPO_DIR}"

if [[ ! -d .git ]]; then
  echo "[deploy][error] ${REPO_DIR} is not a git repository"
  exit 1
fi

git fetch origin
git checkout "${BRANCH}"
git pull --ff-only origin "${BRANCH}"

if [[ ! -x .venv/bin/python3 ]]; then
  "${PYTHON_BIN}" -m venv .venv
fi

.venv/bin/pip install --upgrade pip >/dev/null
.venv/bin/pip install -r requirements.txt

systemctl daemon-reload
systemctl restart "${SERVICE_NAME}"
systemctl --no-pager --full status "${SERVICE_NAME}" | sed -n '1,20p'

for _ in $(seq 1 20); do
  if curl -fsS "http://${APP_HOST}:${APP_PORT}/api/health"; then
    echo
    echo "[deploy] health check ok"
    echo "[deploy] done"
    exit 0
  fi
  sleep 1
done

echo "[deploy][error] health check failed after retries"
exit 1
