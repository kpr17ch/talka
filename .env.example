# Server
VOICE_BRIDGE_HOST=127.0.0.1
VOICE_BRIDGE_PORT=8089
MAX_AUDIO_MB=15
REQUEST_TIMEOUT_SECONDS=120
CORS_ALLOW_ORIGINS=https://voice.example.com
RATE_LIMIT_PER_MINUTE=30
TURN_JOB_TTL_SECONDS=3600
TURN_JOB_MAX_ENTRIES=500
TURN_POLL_AFTER_MS=1200
TURN_ACK_TEXT=
WAKE_PHRASE=hey al
WAKE_PHRASE_SIMILARITY_THRESHOLD=0.8
WAKE_PHRASE_MAX_OFFSET_TOKENS=2

# OpenClaw call
OPENCLAW_BIN=openclaw
OPENCLAW_CHANNEL=telegram
OPENCLAW_TO=telegram:<chat_id_or_plain_chat_id>
OPENCLAW_TIMEOUT_SECONDS=300
OPENCLAW_PROCESS_GRACE_SECONDS=15
MIRROR_USER_TEXT_TO_TELEGRAM=false
USER_TEXT_MIRROR_CHANNEL=telegram
USER_TEXT_MIRROR_TARGET=
USER_TEXT_MIRROR_LABEL=Kai (Web)
USER_TEXT_MIRROR_MAX_CHARS=1200
USER_TEXT_MIRROR_TIMEOUT_SECONDS=30

# STT
STT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1
STT_OPENAI_MAX_RETRIES=1
STT_OPENAI_RETRY_BACKOFF_MS=250
STT_LANGUAGE=de
LOCAL_WHISPER_MODEL=small

# Orchestrator
ORCHESTRATOR_MODE=rules
ORCHESTRATOR_MODEL=gpt-4o-mini
ORCHESTRATOR_MAX_SPEAK_CHARS=1200
ORCHESTRATOR_VOICE_MAX_SENTENCES=4
ORCHESTRATOR_VOICE_DETAIL_HINT=true
ORCHESTRATOR_LLM_TIMEOUT_SECONDS=15
PANEL_STATE_TTL_SECONDS=3600

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=4x4CVzii7ah9rNOudn4i
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.76
ELEVENLABS_SIMILARITY_BOOST=0.91
ELEVENLABS_SPEED=0.84
ELEVENLABS_STYLE=0.12

# Logging
DEBUG_LOG_FULL_TEXT=false
